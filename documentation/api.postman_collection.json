		{
			"name": "create new system",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var responseJSON = pm.response.json();",
							"var responseData = responseJSON.data;",
							"",
							"// Test the response status code",
							"pm.test(\"Response status code is 201\", function () {",
							"  pm.response.to.have.status(201);",
							"});",
							"",
							"// Test the response body structure and values",
							"pm.test(\"Response body structure is valid\", function () {",
							"    pm.expect(responseData).to.have.property('key');",
							"    pm.expect(responseData).to.have.property('id');",
							"    pm.expect(responseData).to.have.property('name');",
							"    pm.expect(responseData).to.have.property('generation');",
							"    pm.expect(responseData).to.have.property('handheld');",
							"    pm.expect(responseData).to.have.property('createdAt');",
							"    pm.expect(responseData).to.have.property('updatedAt');",
							"    pm.expect(responseData).to.have.property('deletedAt');",
							"    pm.expect(responseData).to.have.property('customFieldValues');",
							"});",
							"",
							"// Check that the name property is not empty",
							"pm.test(\"Name property is not empty\", function () {",
							"  pm.expect(responseData.name).to.exist.and.to.have.lengthOf.at.least(1, \"Name should not be empty\");",
							"});",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"system\": {\r\n        \"name\": \"Switch\",\r\n        \"generation\": 9,\r\n        \"handheld\": true,\r\n        \"customFieldValues\": [\r\n                    {\r\n                        \"customFieldId\": 2,\r\n                        \"customFieldName\": \"Release Year\",\r\n                        \"customFieldType\": \"number\",\r\n                        \"value\": \"2017\"\r\n                    }\r\n        ]\r\n    }\r\n}",
