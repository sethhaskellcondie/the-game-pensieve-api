  ],
  "clients": [
    {
      "clientId": "pensieve-web",
      "name": "Pensieve Web (BFF)",
      "description": "Confidential OIDC client for the Next.js BFF (authorization-code + PKCE). Server-side only.",
      "enabled": true,
      "publicClient": false,
      "secret": "${PENSIEVE_WEB_CLIENT_SECRET}",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://${PENSIEVE_APP_DOMAIN}/api/auth/callback"
      ],
      "webOrigins": [
        "https://${PENSIEVE_APP_DOMAIN}"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://${PENSIEVE_APP_DOMAIN}/*"
      },
      "defaultClientScopes": [
        "acr",
        "basic",
        "email",
        "profile",
        "roles",
        "web-origins",
        "pensieve:read"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ]
}
