# Backend REST API base URL, including the /v1 prefix.
#   Local host dev:          http://localhost:8080/v1
#   Docker compose network:  http://backend:8080/v1
API_BASE_URL=http://localhost:8080/v1

# Port the Streamable HTTP MCP server listens on (container port).
PORT=3000

# Per-request timeout to the backend, in milliseconds.
API_TIMEOUT_MS=15000
