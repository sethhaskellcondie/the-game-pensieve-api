# Backend REST API base URL, including the /v1 prefix.
#   Local host dev:          http://localhost:8080/v1
#   Docker compose network:  http://backend:8080/v1
API_BASE_URL=http://localhost:8080/v1

# Port the Streamable HTTP MCP server listens on (container port).
PORT=3000

# Per-request timeout to the backend, in milliseconds.
API_TIMEOUT_MS=15000

# --- OAuth (Phase 4) --------------------------------------------------------
# Enforcement mode:
#   auto     (default) enforce iff the backend heartbeat reports secureMode=true
#   required always enforce (useful for testing the secure path against a local backend)
#   disabled never enforce (tokenless)
MCP_AUTH_MODE=auto

# Expected token issuer (canonical, host-facing) — also advertised in protected-resource metadata.
MCP_OAUTH_ISSUER=http://localhost:8081/realms/pensieve
# JWKS URL for signature verification. Host dev: localhost:8081; compose network: keycloak:8080.
MCP_OAUTH_JWKS_URI=http://localhost:8081/realms/pensieve/protocol/openid-connect/certs
# Expected token audience (the canonical /mcp resource URL).
MCP_OAUTH_AUDIENCE=http://localhost:8090/mcp
# Scopes advertised in protected-resource metadata (comma/space separated).
MCP_OAUTH_SCOPES=pensieve:read
