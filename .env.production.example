# Production environment for compose.production.yaml. Copy to `.env` (same directory) and fill in.
# NEVER commit the real `.env`. Bring the stack up with: docker compose -f compose.production.yaml up -d

# --- Public hostnames (each needs a DNS A/AAAA record pointing at this host, for Caddy's ACME challenge) ---
APP_DOMAIN=pensieve.example.com
MCP_DOMAIN=mcp.example.com
AUTH_DOMAIN=auth.example.com

# --- TLS: Let's Encrypt account email for Caddy automatic HTTPS ---
ACME_EMAIL=you@example.com

# --- Secrets (generate strong, unique values; e.g. `openssl rand -base64 48`) ---
# Encrypts the frontend BFF session cookie (iron-session). Must be >= 32 chars.
SESSION_SECRET=
# Becomes the pensieve-web confidential client's secret: Keycloak resolves it into the realm import
# (keycloak/import-prod/pensieve-realm.json) via the PENSIEVE_WEB_CLIENT_SECRET placeholder on first boot.
OIDC_CLIENT_SECRET=
# App database (Postgres) password.
POSTGRES_PASSWORD=
# Keycloak database (separate Postgres) password.
KC_DB_PASSWORD=
# Keycloak bootstrap admin.
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=

# --- Derived values (FYI — the compose file builds these from the vars above, and Keycloak resolves them
#     into the production realm import (keycloak/import-prod/pensieve-realm.json) on first boot. After the
#     first deploy, verify a decoded token matches — see the header of compose.production.yaml):
#       OIDC / token issuer : https://${AUTH_DOMAIN}/realms/pensieve
#       MCP resource (aud)  : https://${MCP_DOMAIN}/mcp
#       Web login callback  : https://${APP_DOMAIN}/api/auth/callback
